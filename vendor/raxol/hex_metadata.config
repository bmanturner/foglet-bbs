  {<<"GitHub">>,<<"https://github.com/DROOdotFOO/raxol">>}]}.
{<<"name">>,<<"raxol">>}.
{<<"version">>,<<"2.4.0">>}.
{<<"description">>,
 <<"AGI-ready terminal framework for Elixir. 30+ widgets, flexbox + CSS grid,\nTEA on OTP, AI agent runtime, distributed swarm with CRDTs, time-travel\ndebugging, session recording, sandboxed REPL, and SSH serving.">>}.
{<<"elixir">>,<<"~> 1.17 or ~> 1.18 or ~> 1.19">>}.
