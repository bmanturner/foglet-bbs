# Foglet BBS environment template.
#
# Copy values you need into `.env.local` for local development, or set them in
# your deployment platform. Real environment variables override `.env.local`.

# ---------------------------------------------------------------------------
# Production-required Phoenix / database settings
# ---------------------------------------------------------------------------

# Required in production. Local development can use the dev DATABASE_URL in the
# local development section below.
# DATABASE_URL=ecto://USER:PASS@HOST/DATABASE

# Required in production. Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Required by production checks; used as the public HTTP host.
PHX_HOST=example.com

# Enables the Phoenix endpoint in releases.
PHX_SERVER=true

# HTTP listener port. Defaults to 4000.
PORT=4000

# Production Repo pool size. Defaults to 10.
POOL_SIZE=10

# Use IPv6 socket options for Ecto when set to true or 1.
ECTO_IPV6=false

# Optional Erlang distribution clustering query.
# DNS_CLUSTER_QUERY=

# ---------------------------------------------------------------------------
# Local development database
# ---------------------------------------------------------------------------

# docker-compose.yml maps the Postgres container to this host port.
POSTGRES_PORT=5432

# Matches docker-compose.yml defaults.
DATABASE_URL=ecto://postgres:postgres@localhost/foglet_bbs_dev

# ---------------------------------------------------------------------------
# SSH / terminal service
# ---------------------------------------------------------------------------

# Foglet SSH daemon port. Defaults to 2222.
FOGLET_SSH_PORT=2222

# Directory where SSH host keys are stored. In production, mount this on
# persistent storage so clients do not see a new host key after every deploy.
SSH_HOST_KEY_DIR=priv/ssh

# System-wide default timezone for new users and guest sessions. Must be a
# valid IANA timezone name. When unset, Foglet falls back to OS detection and
# then Etc/UTC.
FOGLET_DEFAULT_TIMEZONE=Etc/UTC

# Deployment-level guest-mode override. Accepted values: true, false, 1, 0.
# When unset, DB-backed runtime config decides guest mode.
FOGLET_GUEST_MODE_ENABLED=true

# ---------------------------------------------------------------------------
# Email / SMTP
# ---------------------------------------------------------------------------

# Sender address for outbound email.
# FOGLET_MAIL_FROM=no-reply@example.com

# SMTP relay host. FOGLET_SMTP_HOST is accepted as an alias.
# FOGLET_SMTP_RELAY=smtp.example.com
# FOGLET_SMTP_HOST=smtp.example.com

# SMTP connection options.
# FOGLET_SMTP_PORT=587
# FOGLET_SMTP_USERNAME=
# FOGLET_SMTP_PASSWORD=
# FOGLET_SMTP_SSL=false
# FOGLET_SMTP_TLS=if_available
# FOGLET_SMTP_AUTH=if_available

# ---------------------------------------------------------------------------
# Door Games
# ---------------------------------------------------------------------------

# Optional operator-managed directory of Door Games JSON manifests. When unset
# or blank, operator door loading is disabled.
# FOGLET_DOOR_MANIFEST_DIR=/data/door-manifests

# Enables bundled demo/test doors for local development, QA, demos, and release
# verification. Accepted truthy values: true, 1, yes. Leave false/blank for
# normal instances.
FOGLET_ENABLE_DEMO_DOORS=false

# Classic dropfile default sysop name. Used when generating DORINFO.DEF.
FOGLET_BBS_SYSOP_NAME=Foglet Sysop

# ---------------------------------------------------------------------------
# Test-only
# ---------------------------------------------------------------------------

# ExUnit partition suffix for parallel test databases.
# MIX_TEST_PARTITION=1

# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------

# Foglet generates FOGLET_DOOR_ID, FOGLET_USER_ID, FOGLET_USERNAME,
# FOGLET_SESSION_ID, FOGLET_TERMINAL_WIDTH, FOGLET_TERMINAL_HEIGHT,
# FOGLET_DOOR_CONTEXT, FOGLET_DROPFILES, FOGLET_DROPFILE_DIR, and per-format
# FOGLET_DROPFILE_* variables for launched door processes. Do not set those on
# the Foglet application process.
