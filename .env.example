# Required in production
DATABASE_URL=ecto://USER:PASS@HOST/DATABASE
SECRET_KEY_BASE=                        # mix phx.gen.secret
PHX_HOST=example.com

# Optional (shown with defaults)
PORT=4000
POOL_SIZE=10
PHX_SERVER=true
ECTO_IPV6=false
DNS_CLUSTER_QUERY=

# SSH daemon (Milestone 3+)
SSH_PORT=2222
SSH_HOST_KEY_DIR=priv/ssh

# Observability (Milestone 10+)
SENTRY_DSN=
