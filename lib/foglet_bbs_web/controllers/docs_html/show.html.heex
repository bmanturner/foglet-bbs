<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{@page.title} · foglet docs</title>
    <link rel="stylesheet" href="/assets/docs.css" />
  </head>
  <body>
    <div class="page">
      <div class="bar">
        <span>foglet · ssh-first terminal bbs · /docs/{@page.category}/{@page.id}</span>
        <span class="bar-actions">
          <span class="live">BETA</span>
          <span class="sep">│</span>
          <a href="/">← landing</a>
          <span class="sep">│</span>
          <a href="https://github.com/bmanturner/foglet-bbs" target="_blank" rel="noopener">
            GitHub
          </a>
        </span>
      </div>

      <div class="shell">
        <.sidebar groups={@groups} active={{@page.category, @page.id}} />

        <main class="article">
          <p class="crumbs">
            <a href="/docs/start-here/overview">Docs</a>
            <span class="sep">/</span>
            <span>{@page.category_title}</span>
            <span class="sep">/</span>
            <span>{@page.title}</span>
          </p>

          <h1>{@page.title}</h1>
          <p :if={@page.description != ""} class="lede">{@page.description}</p>

          <article class="prose">
            {Phoenix.HTML.raw(@page.body)}
          </article>

          <div class="footer">
            <a href="/docs/start-here/overview">← docs home</a>
            <span>foglet bbs · /{@page.category}/{@page.id}</span>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
