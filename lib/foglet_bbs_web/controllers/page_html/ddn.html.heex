  <body>
    <div class="bar-top">
      <div class="nodes">
        <span>FOGLET BBS</span>
        <span>doors/drop-dead-nebula</span>
        <span>v0.1 · season 1</span>
      </div>
      <div>guest · <span id="clk">--:--</span></div>
    </div>

    <div class="bar-bot">
      <div class="keys">
        <span><b>[PgDn]</b> scroll</span>
        <span><b>[C]</b>onnect</span>
        <span><b>[D]</b>oors</span>
        <span><b>[F]</b>aq</span>
        <span><b>[G]</b>oodbye</span>
      </div>
      <div>ssh bbs.foglet.io</div>
    </div>

    <div class="screen-wrap flicker">
      <section class="hero">
        <div class="starfield" aria-hidden="true">
          <pre>     .                 ·              ·     ·                          .

